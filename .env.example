# Supabase (public — safe for client bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma / Postgres
DATABASE_URL=          # Supabase pooler (port 6543) — used at runtime
DIRECT_URL=            # Supabase direct (port 5432) — used for migrations only

# Anthropic (server-only — no NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=
